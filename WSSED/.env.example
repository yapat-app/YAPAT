# WSSED-YAPAT — copy to `.env` in this directory and adjust.
# `wssed_gpu_server.py` and `install.sh` load `.env` automatically (install.sh uses bash `source`).
# Values already set in the shell take precedence over this file (python-dotenv default).

# Root for relative dataset_path from YAPAT training requests
WSSED_DATA_ROOT=/ds-iml/Bioacoustics

# Writable directory for job state, status.json, generated configs
WSSED_JOBS_DIR=/wssed_jobs

# install.sh: where to write install-*.log (empty = use default $HOME/wssed-install-logs)
# WSSED_INSTALL_LOGDIR=/path/to/logs

# wssed_gpu_server.py (python -m or __main__)
WSSED_HOST=0.0.0.0
WSSED_PORT=8004
WSSED_GPU_DEVICE_ID=2
